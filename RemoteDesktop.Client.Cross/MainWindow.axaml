<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="RemoteDesktop.Client.Cross.MainWindow"
        Title="Remote Desktop Client (Cross)">
  <Grid RowDefinitions="Auto,*" Margin="10">
    <Grid ColumnDefinitions="280,90,100,*" RowDefinitions="Auto">
      <TextBox x:Name="HostTextBox" Grid.Column="0" Watermark="Host IP" Text="127.0.0.1"/>
      <TextBox x:Name="PortTextBox" Grid.Column="1" Margin="8,0,0,0" Text="5050"/>
      <Button x:Name="ConnectButton" Grid.Column="2" Margin="8,0,0,0" Content="Connect" Click="ConnectButton_Click"/>
      <TextBlock x:Name="StatusTextBlock" Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center" Text="Idle..."/>
    </Grid>

    <Border Grid.Row="1" Margin="0,10,0,0" Background="Black">
      <Image x:Name="ScreenImage"
             Stretch="Uniform"
             PointerMoved="ScreenImage_PointerMoved"
             PointerPressed="ScreenImage_PointerPressed"
             PointerReleased="ScreenImage_PointerReleased"/>
    </Border>
  </Grid>
</Window>
